# ===== الواجهة الأمامية (Next.js) =====
# عنوان الـ API الخلفي (ORDS) — مثال على Oracle Cloud
BACKEND_API_URL=https://api.madinah-rehab.sa/ords/rehab/api/v1
NEXT_PUBLIC_API_BASE=/api/backend

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# مزوّدو الدخول الاجتماعي
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# OAuth2 ضد ORDS (client_credentials للمسارات المحمية)
ORDS_OAUTH_CLIENT_ID=
ORDS_OAUTH_CLIENT_SECRET=
